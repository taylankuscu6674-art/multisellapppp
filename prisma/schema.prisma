generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MarketplacePlatform {
  DOLAP
  GARDROPS
  LETGO
}

enum ConnectedAccountStatus {
  CONNECTED
  NEEDS_REVIEW
  EXPIRED
  MANUAL_ONLY
  DISCONNECTED
}

enum IntegrationMode {
  OFFICIAL_API
  PARTNER_API
  IMPORT_EXPORT
  MANUAL
}

enum ProductStatus {
  DRAFT
  READY
  PUBLISHED
  SOLD
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  RESERVED
  SOLD_OUT
}

enum ListingStatus {
  DRAFT
  READY
  PUBLISHED
  FAILED
  MANUAL_ACTION_NEEDED
  SOLD
  ARCHIVED
}

enum PublishAction {
  PUBLISH
  UPDATE
  ARCHIVE
  SYNC
}

enum ActivitySeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  image             String?
  role              String             @default("owner")
  connectedAccounts ConnectedAccount[]
  products          Product[]
  activityLogs      ActivityLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ConnectedAccount {
  id              String                 @id @default(cuid())
  userId          String
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        MarketplacePlatform
  displayName     String
  status          ConnectedAccountStatus @default(MANUAL_ONLY)
  integrationMode IntegrationMode         @default(MANUAL)
  supported       Boolean                @default(false)
  tokenEncrypted  String?
  refreshSecret   String?
  scopes          String[]
  metadata        Json?
  lastHealthCheck DateTime?
  expiresAt       DateTime?
  listings        MarketplaceListing[]
  publishJobs     PublishJob[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([userId, platform])
  @@index([platform, status])
}

model Product {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  shortDescription String?
  description      String
  category         String
  brand            String?
  condition        String
  size             String?
  color            String?
  price            Decimal                 @db.Decimal(10, 2)
  currency         String                  @default("TRY")
  shippingInfo     Json
  stockStatus      StockStatus             @default(IN_STOCK)
  status           ProductStatus           @default(DRAFT)
  tags             String[]
  images           ProductImage[]
  listings         MarketplaceListing[]
  publishJobs      PublishJob[]
  overrides        PlatformFieldOverride[]
  activityLogs     ActivityLog[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([userId, status])
  @@index([category])
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  storageKey String?
  alt        String
  order      Int      @default(0)
  isCover    Boolean  @default(false)
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())

  @@index([productId, order])
}

model MarketplaceListing {
  id                 String             @id @default(cuid())
  productId          String
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  connectedAccountId String?
  connectedAccount   ConnectedAccount?  @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  platform           MarketplacePlatform
  status             ListingStatus      @default(DRAFT)
  platformListingId  String?
  listingUrl         String?
  lastSyncedAt       DateTime?
  missingFields      String[]
  responseDetails    Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([productId, platform])
  @@index([platform, status])
}

model PublishJob {
  id                 String             @id @default(cuid())
  productId          String
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  connectedAccountId String?
  connectedAccount   ConnectedAccount?  @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  platform           MarketplacePlatform
  action             PublishAction
  status             ListingStatus
  requestPayload     Json?
  responsePayload    Json?
  errorMessage       String?
  createdAt          DateTime           @default(now())
  completedAt        DateTime?

  @@index([platform, status])
  @@index([createdAt])
}

model ActivityLog {
  id          String               @id @default(cuid())
  userId      String?
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId   String?
  product     Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  platform    MarketplacePlatform?
  type        String
  title       String
  description String
  severity    ActivitySeverity     @default(INFO)
  metadata    Json?
  createdAt   DateTime             @default(now())

  @@index([platform, createdAt])
  @@index([severity])
}

model PlatformFieldOverride {
  id             String              @id @default(cuid())
  productId      String
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform       MarketplacePlatform
  title          String?
  description    String?
  category       String?
  price          Decimal?            @db.Decimal(10, 2)
  shippingOption String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([productId, platform])
}
